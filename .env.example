APP_VERSION=0.1.0

SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8765/api/v1/spotify/auth/callback
SPOTIFY_SCOPES=user-read-private user-library-read playlist-read-private playlist-read-collaborative

# Phase 1 note: tokens are stored locally for development only (SQLite).
# Do not commit tokens or database files. Plan: migrate to OS keychain/encrypted storage later.
SPOTIFY_AUTH_STORAGE=sqlite

DATABASE_URL=sqlite:////app/data/spotify_curator.sqlite
# WAL with named Docker volume spotify_curator_data (default). DELETE only if using bind mount ./data.
SQLITE_JOURNAL_MODE=WAL
CACHE_DIR=/app/cache
MODELS_DIR=/app/models
LOGS_DIR=/app/logs

# Exports (generated files, local only; should be git-ignored)
EXPORT_DIR=/app/exports

CORE_HOST=127.0.0.1
CORE_PORT=8765
JOB_DEFAULT_MAX_ATTEMPTS=3

RECCOBEATS_BASE_URL=https://api.reccobeats.com
RECCOBEATS_TIMEOUT_SECONDS=15
RECCOBEATS_MAX_RETRIES=3
RECCOBEATS_BATCH_DELAY_MS=100
RECCOBEATS_HTTP_BATCH_SIZE=40
RECCOBEATS_DB_UPSERT_BATCH_SIZE=50
RECCOBEATS_ENRICH_DEFAULT_LIMIT=5000
RECCOBEATS_ENRICH_MAX_LIMIT=10000

# Jobs / workers
JOB_WORKER_HEARTBEAT_INTERVAL_SECONDS=10
JOB_ITEM_LOCK_TIMEOUT_SECONDS=600
JOB_EVENTS_ENABLED=true
WORKER_HEARTBEATS_ENABLED=true

# Audio
AUDIO_SEGMENT_MAX_SECONDS=30
AUDIO_KEEP_SEGMENTS_AFTER_ANALYSIS=false
AUDIO_DEBUG_KEEP_FAILED_SEGMENTS=false
AUDIO_DOWNLOAD_WORKERS=2
AUDIO_DOWNLOAD_CONCURRENCY=2
AUDIO_DOWNLOAD_MAX_RETRIES=3
AUDIO_DOWNLOAD_BATCH_SIZE=20
AUDIO_DOWNLOAD_ITEM_LOCK_TIMEOUT_SECONDS=600
AUDIO_SEGMENT_DEFAULT_SECONDS=15
AUDIO_SEGMENT_STRATEGY=hybrid_deezer_youtube_representative

# Deezer previews (metadata / UI streaming only)
DEEZER_API_BASE_URL=https://api.deezer.com
DEEZER_TIMEOUT_SECONDS=15
DEEZER_MAX_RETRIES=3
DEEZER_PREVIEW_UI_MIN_CONFIDENCE=0.55
DEEZER_PREVIEW_ANALYSIS_MIN_CONFIDENCE=0.70
YOUTUBE_MIN_CONFIDENCE=0.50
AUDIO_PREVIEW_CACHE_METADATA_DAYS=7
AUDIO_PREVIEWS_ENABLED=true
CONFIDENCE_WEIGHT_YOUTUBE_REPRESENTATIVE=0.95
CONFIDENCE_WEIGHT_YOUTUBE_FALLBACK_THREE=1.00
CONFIDENCE_WEIGHT_DEEZER_PREVIEW_ONLY=0.70
AUDIO_ENRICH_DEFAULT_LIMIT=5000
AUDIO_ENRICH_MAX_LIMIT=10000

# yt-dlp / ffmpeg
YTDLP_FORMAT=bestaudio/best
YTDLP_TIMEOUT_SECONDS=120
FFMPEG_TIMEOUT_SECONDS=120
YTDLP_DURATION_TOLERANCE_SECONDS=15

# Essentia low-level
ESSENTIA_LOWLEVEL_WORKERS=2
ESSENTIA_LOWLEVEL_ITEM_MODE=track
ESSENTIA_LOWLEVEL_MAX_RETRIES=2
ESSENTIA_LOWLEVEL_PROFILE=/app/profiles/essentia_lowlevel_basic.yaml
ESSENTIA_LOWLEVEL_PIPELINE_VERSION=essentia_lowlevel_v1
ESSENTIA_LOWLEVEL_ITEM_LOCK_TIMEOUT_SECONDS=900
ESSENTIA_LOWLEVEL_IMAGE=ghcr.io/mtg/essentia
ESSENTIA_LOWLEVEL_IMAGE_TAG=bullseye-v2.1_beta5
ESSENTIA_LOWLEVEL_TIMEOUT_SECONDS=180

# Essentia TensorFlow models (phase 6)
ESSENTIA_MODELS_DIR=/app/models/essentia
ESSENTIA_MODELS_MANIFEST=/app/core/app/models_registry/essentia_models_manifest.yaml
ESSENTIA_MODELS_DEFAULT_PROFILE=phase6-recommended
ESSENTIA_MODELS_DOWNLOAD_TIMEOUT_SECONDS=300
ESSENTIA_MODELS_VERIFY_HASH=true
ESSENTIA_MODELS_ACCEPT_LICENSE=false

# Essentia TensorFlow inference (phase 6)
ESSENTIA_TF_REAL_INFERENCE_ENABLED=true
ESSENTIA_TF_ALLOW_STUBS_IN_TESTS=false
ESSENTIA_TF_REQUIRE_MODELS_FOR_ADVANCED=false
ESSENTIA_TF_FAIL_ON_STUB_IN_PRODUCTION=true
ESSENTIA_TENSORFLOW_WORKERS=1
ESSENTIA_TENSORFLOW_BATCH_SIZE=8
ESSENTIA_TENSORFLOW_ITEM_LOCK_TIMEOUT_SECONDS=1800

# Test-only: use TestAudioProvider in audio-downloader worker
# AUDIO_USE_TEST_PROVIDER=true
