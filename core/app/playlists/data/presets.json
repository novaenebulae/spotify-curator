[
  {
    "id": "dark_intense",
    "label": "Dark / Intense",
    "description": "High energy, lower valence. Needs ReccoBeats features on candidates.",
    "rule": {
      "name": "Dark / Intense",
      "target_size": 80,
      "engine_version": "playlist_engine_v1",
      "source": { "liked_tracks": true },
      "filters": {
        "features": {
          "energy": { "min": 0.5, "required": true },
          "valence": { "max": 0.65, "required": false },
          "danceability": { "min": 0.35, "required": false },
          "feature_confidence": { "min": 0.35, "required": false }
        }
      },
      "weights": {
        "missing_component_behavior": "skip_and_renormalize",
        "components": {
          "energy": { "weight": 0.3 },
          "valence_inverse": { "weight": 0.2 },
          "danceability": { "weight": 0.15 },
          "freshness_score": { "weight": 0.1 },
          "playlist_fit_score": { "weight": 0.15 },
          "diversity_bonus": { "weight": 0.1 }
        }
      },
      "constraints": {
        "max_tracks_per_artist": 3,
        "max_tracks_per_album": 2,
        "avoid_duplicate_isrc": true
      },
      "ordering": { "mode": "score_desc", "random_seed": 42 },
      "spotify": {
        "playlist_name": "Dark / Intense",
        "visibility": "private",
        "sync_mode": "replace_after_dry_run"
      }
    }
  },
  {
    "id": "calm_focus",
    "label": "Calm / Focus",
    "description": "Low energy, moderate valence. Works with energy filter only.",
    "rule": {
      "name": "Calm / Focus",
      "target_size": 60,
      "engine_version": "playlist_engine_v1",
      "source": { "liked_tracks": true },
      "filters": {
        "features": {
          "energy": { "max": 0.45, "required": true },
          "valence": { "min": 0.25, "max": 0.75, "required": false },
          "acousticness": { "min": 0.2, "required": false }
        }
      },
      "weights": {
        "missing_component_behavior": "skip_and_renormalize",
        "components": {
          "energy": { "weight": 0.35 },
          "valence": { "weight": 0.25 },
          "acousticness": { "weight": 0.2 },
          "freshness_score": { "weight": 0.2 }
        }
      },
      "constraints": { "max_tracks_per_artist": 4, "avoid_duplicate_isrc": true },
      "ordering": { "mode": "score_desc" },
      "spotify": { "playlist_name": "Calm / Focus", "sync_mode": "replace_after_dry_run" }
    }
  },
  {
