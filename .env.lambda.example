# Spotify Curator — Lambda Labs GPU mode
# Copy to .env.lambda on the instance:  cp .env.lambda.example .env.lambda
#
# How this file is used (two roles):
# 1) CLI:  docker compose ... --env-file .env.lambda
#    → substitutes ${VAR} in docker-compose.yml x-app-env (same as local .env).
# 2) Container:  env_file: .env.lambda in docker-compose.lambda.yml
#    → injects KEY=VALUE into each service process (read by pydantic Settings).
#
# Most pipeline variables (Deezer, yt-dlp, ReccoBeats, analysis tick…) come from
# x-app-env defaults in docker-compose.yml. Override below for Lambda-specific values.
#
# Required before first run: set SPOTIFY_CLIENT_ID and register redirect URI in
# Spotify Developer Dashboard:
#   http://127.0.0.1:8000/api/v1/spotify/auth/callback
# Use 127.0.0.1 — not localhost — for OAuth loopback.

# --- Runtime marker ---
APP_ENV=lambda
RUN_ENV=lambda

# --- Paths (Lambda SSD bind mounts) ---
DATA_DIR=/app/data
SQLITE_PATH=/app/data/spotify_curator.sqlite
DATABASE_URL=sqlite:////app/data/spotify_curator.sqlite
SQLITE_JOURNAL_MODE=WAL
CACHE_DIR=/app/temp-audio
MODELS_DIR=/app/models
LOGS_DIR=/app/logs
EXPORT_DIR=/app/exports

# --- Spotify OAuth (required for main workflow: import library on Lambda) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/v1/spotify/auth/callback
SPOTIFY_SCOPES=user-read-private user-library-read playlist-read-private playlist-read-collaborative
SPOTIFY_AUTH_STORAGE=sqlite

# --- Docker scale (Makefile lambda-up-a100 / lambda-up-a10) ---
ESSENTIA_TENSORFLOW_WORKERS=1
ESSENTIA_LOWLEVEL_WORKERS=1
AUDIO_DOWNLOAD_WORKERS=2
PREVIEW_RESOLVER_WORKERS=1

# --- Audio download (conservative — raise only if GPU waits for segments) ---
AUDIO_DOWNLOAD_CONCURRENCY=2
AUDIO_DOWNLOAD_MAX_RETRIES=3
AUDIO_DOWNLOAD_BATCH_SIZE=20
AUDIO_DOWNLOAD_ITEM_LOCK_TIMEOUT_SECONDS=600

# --- Analysis pipeline ---
ANALYSIS_PIPELINE_MODE=streaming
ANALYSIS_ADVANCED_ENABLED=true
ANALYSIS_DEFAULT_INCLUDE_TENSORFLOW=true
ANALYSIS_PIPELINE_TICK_ENABLED=true
ANALYSIS_PIPELINE_TICK_INTERVAL_SECONDS=45
AUDIO_CLEANUP_WAIT_FOR_ALL_CONSUMERS=true

# --- Essentia low-level ---
ESSENTIA_LOWLEVEL_PROFILE=/app/profiles/essentia_lowlevel_full.yaml
ESSENTIA_LOWLEVEL_PIPELINE_VERSION=essentia_lowlevel_v2_full
ESSENTIA_LOWLEVEL_MAX_RETRIES=2
ESSENTIA_LOWLEVEL_ITEM_MODE=track
ESSENTIA_LOWLEVEL_ITEM_LOCK_TIMEOUT_SECONDS=900
ESSENTIA_LOWLEVEL_TIMEOUT_SECONDS=180

# --- Essentia TensorFlow / models (download from UI on Lambda → NFS /app/models) ---
ESSENTIA_MODEL_PROFILE=phase6-recommended
ESSENTIA_MODELS_DEFAULT_PROFILE=phase6-recommended
ESSENTIA_MODELS_DIR=/app/models/essentia
ESSENTIA_MODELS_MANIFEST=/app/core/app/models_registry/essentia_models_manifest.yaml
ESSENTIA_MODELS_VERIFY_HASH=true
ESSENTIA_MODELS_ACCEPT_LICENSE=false
ESSENTIA_TENSORFLOW_PIPELINE_VERSION=essentia_tensorflow_v1
ESSENTIA_TF_PIPELINE_VERSION=phase6_tf_unified_v1
ESSENTIA_TF_REAL_INFERENCE_ENABLED=true
ESSENTIA_TF_ALLOW_STUBS_IN_TESTS=false
ESSENTIA_TF_REQUIRE_MODELS_FOR_ADVANCED=false
ESSENTIA_TF_FAIL_ON_STUB_IN_PRODUCTION=true
ESSENTIA_TENSORFLOW_MAX_RETRIES=1
ESSENTIA_TENSORFLOW_ITEM_LOCK_TIMEOUT_SECONDS=1800
ESSENTIA_TENSORFLOW_STATUS_ONLY=false
ESSENTIA_TF_DEVICE=gpu
ESSENTIA_TF_WARMUP=false
ESSENTIA_TF_BATCH_SIZE=1
ESSENTIA_TF_BATCH_TIMEOUT_MS=1000
ESSENTIA_TENSORFLOW_BATCH_SIZE=1

# --- TensorFlow / NVIDIA runtime ---
TF_FORCE_GPU_ALLOW_GROWTH=true
TF_CPP_MIN_LOG_LEVEL=1
TF_NUM_INTRAOP_THREADS=4
TF_NUM_INTEROP_THREADS=2
OMP_NUM_THREADS=4
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# --- Frontend (SSH tunnel — use 127.0.0.1, not localhost) ---
VITE_API_BASE_URL=http://127.0.0.1:8000

